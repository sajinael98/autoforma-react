{
  "name": "autoforma-react",
  "version": "1.1.0",
  "description": "Schema-driven form generator for React built on top of React Hook Form.",
  "author": "Saji Nael",
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://sajinael98.github.io/autoforma-react",
  "repository": {
    "type": "git",
    "url": "https://github.com/sajinael98/autoforma-react.git"
  },
  "keywords": [
    "react",
    "forms",
    "form-builder",
    "form-generator",
    "react-hook-form",
    "typescript",
    "schema",
    "dynamic-forms",
    "autoforma"
  ],
  "type": "module",
  "main": "./dist/auto-forma.js",
  "module": "./dist/auto-forma.js",
  "types": "./dist/src/lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/lib/index.d.ts",
      "import": "./dist/auto-forma.js",
      "default": "./dist/auto-forma.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build",
    "lint": "eslint .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "preview-storybook": "storybook preview",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "react-hook-form": ">=7"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@eslint/js": "^10.0.1",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^10.4.6",
    "globals": "^17.6.0",
    "playwright": "^1.61.0",
    "storybook": "^10.4.6",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-dts": "^3.9.0",
    "vitest": "^4.1.9"
  }
}
